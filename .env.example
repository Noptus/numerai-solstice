# Numerai API credentials
NUMERAI_PUBLIC_ID=your_public_id_here
NUMERAI_SECRET_KEY=your_secret_key_here

# Submission slot model IDs (get these from numer.ai/models)
# Configure as many slots as you want (1-5). Leave blank to skip a slot.
SLOT_1_MODEL_ID=your_model_id_here
SLOT_2_MODEL_ID=
SLOT_3_MODEL_ID=
SLOT_4_MODEL_ID=
SLOT_5_MODEL_ID=
